# ─────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values.
# .env is gitignored (.gitignore line 2). NEVER commit a populated .env.
# Used by python-dotenv via config/settings/base.py on app boot.
# On the VPS, also referenced by systemd EnvironmentFile=/var/www/glowmathcourse/.env
# ─────────────────────────────────────────────────────────────────────────

# Which settings module Django loads. Dev uses config.settings.dev;
# the prod VPS .env should set this to production.
DJANGO_SETTINGS_MODULE=config.settings.dev

# Required in all environments. Generate a fresh value per environment.
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=your-secret-key-here

# Dev defaults (override for production)
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production — PostgreSQL connection string.
# Hostinger VPS local Postgres (loopback, no SSL):
#   postgres://glowmath_user:STRONG_PASSWORD@localhost:5432/glowmath_prod
# Managed/remote Postgres that requires SSL: also set DATABASE_SSL=1 below.
DATABASE_URL=
DATABASE_SSL=0

# Production — full origins including scheme, comma-separated.
# Example: https://glowmathclass.com,https://www.glowmathclass.com
CSRF_TRUSTED_ORIGINS=

# Optional SMTP. If EMAIL_HOST is unset the prod settings fall back to
# Django's console backend (logs to journalctl, no real send).
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=
