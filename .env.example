# Copy this file to .env and fill in the values.
# Generate SECRET_KEY with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# Required in all environments
SECRET_KEY=your-secret-key-here

# Development defaults (change for production)
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production only — PostgreSQL connection string from Railway / Supabase / etc.
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=

# Production only — full origins including scheme, comma-separated
# Example: https://glowmathcourse.up.railway.app,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=

# Set this to use production settings (wsgi.py sets it automatically)
# DJANGO_SETTINGS_MODULE=config.settings.production
